---
import '../styles/global.css';
import Icon from '../components/ui/Icon.astro';

const { title } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}/dashboard`, label: 'الرئيسية', icon: 'grid' },
  { href: `${base}/dashboard/warehouses`, label: 'إدارة المستودعات', icon: 'warehouse' },
  { href: `${base}/dashboard/products`, label: 'إدارة الأصناف', icon: 'package' },
  { href: `${base}/dashboard/grn`, label: 'المشتريات والاستلام', icon: 'fileUp' },
  { href: `${base}/dashboard/workflows`, label: 'الهيكل والمسارات', icon: 'workflows' },
  { href: `${base}/dashboard/forms`, label: 'النماذج التشغيلية', icon: 'clipboardList' },
];
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} - Brandzo ERP 2026` : 'Brandzo ERP 2026'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
    
    <style is:global>
      body {
        font-family: 'Cairo', sans-serif;
        background-color: #f3f4f6;
      }

      /* إعدادات الباركود والطباعة - تم استعادتها */
      @media print {
        .no-print { display: none !important; }
        body { background-color: white !important; }
        .print-only { display: block !important; }
        .barcode-card {
          break-inside: avoid;
          page-break-inside: avoid;
          border: 1px solid #000 !important;
          margin-bottom: 0.5rem;
        }
      }

      /* تنسيق بطاقات الباركود */
      .barcode-container svg {
        width: 100% !important;
        height: auto !important;
      }

      /* Guide Drawer Styles */
      #guide-drawer {
        margin-right: auto;
        margin-left: 0;
        height: 100vh;
        max-height: 100vh;
        border: none;
        background: rgba(26, 26, 46, 0.8);
        backdrop-filter: blur(12px);
        color: white;
        box-shadow: -10px 0 30px rgba(192, 57, 43, 0.3);
        transform: translateX(-100%);
        transition: transform 0.3s ease-out;
        display: flex;
        flex-direction: column;
        border-right: 2px solid #e8b830;
      }

      #guide-drawer[open] { transform: translateX(0); display: flex; }
      #guide-drawer::backdrop { background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); }
      .neon-glow-gold { box-shadow: 0 0 10px rgba(232, 184, 48, 0.5); }
    </style>
  </head>
  <body class="min-h-screen">

    <header id="brandzo-mobile-header" class="no-print md:hidden fixed top-0 inset-x-0 z-30 flex items-center justify-between bg-brand-navy text-white px-4 py-3 shadow-lg">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-brand-red rounded-lg flex items-center justify-center font-bold text-lg shadow">B</div>
        <span class="font-bold tracking-tight">Brandzo ERP</span>
      </div>
      <button id="brandzo-menu-toggle" type="button" class="p-2 rounded-md hover:bg-gray-800"><Icon name="menu" size={24} /></button>
    </header>

    <aside id="brandzo-sidebar" class="no-print fixed top-0 right-0 h-[100dvh] w-64 max-w-[85vw] bg-brand-navy text-white shadow-xl z-50 flex flex-col transform translate-x-full md:translate-x-0 transition-transform duration-200 ease-out">
      <div class="p-6 border-b border-gray-700 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-brand-red rounded-lg flex items-center justify-center font-bold text-xl shadow-lg">B</div>
          <h1 class="text-xl font-bold tracking-tight">Brandzo ERP</h1>
        </div>
        <button id="brandzo-menu-close" class="md:hidden p-2 rounded-md hover:bg-gray-800"><Icon name="close" size={20} /></button>
      </div>

      <nav class="mt-4 px-4 flex-1 overflow-y-auto">
        <ul class="space-y-1">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-800 transition-colors">
                <Icon name={item.icon} class="text-brand-red" />
                <span class="font-medium">{item.label}</span>
              </a>
            </li>
          ))}
          <li>
            <button id="open-guide" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-800 text-right">
              <Icon name="bookOpen" class="text-brand-gold" />
              <span class="font-medium">الدليل التشغيلي</span>
            </button>
          </li>
        </ul>
      </nav>
    </aside>

    <div id="brandzo-backdrop" class="no-print md:hidden fixed inset-0 bg-black/50 z-40 hidden"></div>

    <main class="md:mr-64 px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8 pt-20 md:pt-8 transition-all">
      <div class="max-w-7xl mx-auto">
        <slot />
      </div>
    </main>

    <dialog id="guide-drawer" class="no-print w-full max-w-[90vw] md:max-w-md">
      <div class="flex items-center justify-between p-4 border-b border-brand-gold/30 bg-brand-navy/50">
        <h2 class="text-xl font-bold text-brand-gold">الدليل التشغيلي</h2>
        <button id="close-guide" class="p-2 hover:bg-white/10 rounded-full"><Icon name="close" size={20} /></button>
      </div>
      <div class="flex-1 overflow-hidden">
        <iframe src={`${base}/Brandzo_Operational_Guide.html`} class="w-full h-full border-none"></iframe>
      </div>
    </dialog>

    <script is:inline>
      (function () {
        const sidebar = document.getElementById('brandzo-sidebar');
        const backdrop = document.getElementById('brandzo-backdrop');
        const toggle = document.getElementById('brandzo-menu-toggle');
        const close = document.getElementById('brandzo-menu-close');
        const guideDrawer = document.getElementById('guide-drawer');
        const openGuideBtn = document.getElementById('open-guide');
        const closeGuideBtn = document.getElementById('close-guide');

        if (!sidebar || !backdrop || !toggle) return;

        const open = () => {
          sidebar.classList.remove('translate-x-full');
          backdrop.classList.remove('hidden');
          document.body.classList.add('overflow-hidden', 'md:overflow-auto');
        };

        const dismiss = () => {
          sidebar.classList.add('translate-x-full');
          backdrop.classList.add('hidden');
          document.body.classList.remove('overflow-hidden', 'md:overflow-auto');
        };

        toggle.addEventListener('click', open);
        close && close.addEventListener('click', dismiss);
        backdrop.addEventListener('click', dismiss);

        // Auto-sync for screen resize
        const mql = window.matchMedia('(min-width: 768px)');
        const sync = () => {
          if (mql.matches) {
            sidebar.classList.remove('translate-x-full');
            backdrop.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
          } else {
            sidebar.classList.add('translate-x-full');
          }
        };
        mql.addEventListener('change', sync);
        sync();

        // Guide Drawer Logic
        if (guideDrawer && openGuideBtn) {
          openGuideBtn.addEventListener('click', () => { dismiss(); guideDrawer.showModal(); });
          closeGuideBtn.addEventListener('click', () => guideDrawer.close());
        }
      })();
    </script>
  </body>
</html>
