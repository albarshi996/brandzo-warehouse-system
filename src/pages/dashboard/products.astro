---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="إدارة الأصناف">
  <div class="text-right" dir="rtl">
    <header class="mb-8">
      <h2 class="text-3xl font-bold text-[#1a1a2e]">إدارة الأصناف (Products)</h2>
      <p class="text-gray-500 mt-1">هذه الصفحة قيد التطوير حالياً</p>
    </header>

    <div class="bg-white p-12 rounded-2xl shadow-sm border border-gray-200 text-center">
      <div
        class="w-20 h-20 bg-red-50 text-[#c0392b] rounded-full flex items-center justify-center mx-auto mb-6"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="m7.5 4.27 9 5.15"></path><path
            d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"
          ></path><path d="m3.27 6.96 8.73 5.05 8.73-5.05"></path><path d="M12 22.08V12"
          ></path></svg
        >
      </div>
      <h3 class="text-2xl font-bold text-gray-800 mb-2">قريباً: إدارة الأصناف والكتالوج</h3>
      <p class="text-gray-500 max-w-md mx-auto leading-relaxed">
        نحن نعمل على بناء واجهة متطورة لإدارة جميع أصناف Brandzo مع دعم كامل للفئات، الوحدات،
        والباركود.
      </p>
    </div>
  </div>
</DashboardLayout>
