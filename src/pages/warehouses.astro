---
import WarehouseManager from '../components/warehouse/WarehouseManager.jsx';
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>إدارة المستودعات - Brandzo ERP 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Cairo', sans-serif;
        background-color: #f3f4f6;
      }
    </style>
  </head>
  <body>
    <header class="bg-[#1a1a2e] text-white p-4 shadow-lg">
      <div class="container mx-auto flex justify-between items-center">
        <h1 class="text-xl font-bold">Brandzo ERP 2026</h1>
        <nav>
          <ul class="flex gap-6">
            <li><a href="/" class="hover:text-[#e8b830] transition-colors">لوحة التحكم</a></li>
            <li><a href="/warehouses" class="text-[#e8b830] font-bold">المستودعات</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container mx-auto py-8">
      <WarehouseManager client:load />
    </main>

    <footer class="mt-12 py-6 bg-white border-t text-center text-gray-500 text-sm">
      <p>&copy; 2024 Brandzo ERP - جميع الحقوق محفوظة</p>
    </footer>
  </body>
</html>
