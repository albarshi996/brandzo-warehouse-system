---
import '../styles/global.css';
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Brandzo ERP 2026 - نظام إدارة الموارد المتكامل</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Cairo', sans-serif;
      }
      .hero-gradient {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      }
    </style>
  </head>
  <body class="bg-gray-50">
    <header class="absolute top-0 w-full p-6 z-10">
      <div class="container mx-auto flex justify-between items-center">
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 bg-[#c0392b] rounded-xl flex items-center justify-center font-black text-2xl text-white shadow-lg"
          >
            B
          </div>
          <span class="text-2xl font-bold text-white tracking-tight">Brandzo ERP</span>
        </div>
      </div>
    </header>

    <main>
      <!-- Hero Section -->
      <section class="hero-gradient min-h-screen flex items-center pt-20 relative overflow-hidden">
        <div
          class="absolute top-0 right-0 w-1/2 h-full bg-[#c0392b] opacity-5 skew-x-12 translate-x-1/2"
        >
        </div>
        <div class="container mx-auto px-6 relative z-10">
          <div class="max-w-3xl">
            <h1 class="text-5xl md:text-7xl font-black text-white leading-tight mb-6">
              المستقبل يبدأ من <span class="text-[#c0392b]">هنا</span>
            </h1>
            <p class="text-xl md:text-2xl text-gray-300 mb-10 leading-relaxed">
              نظام إدارة الموارد المتكامل لإدارة المستودعات، الأصناف، والمشتريات بكل سهولة
              واحترافية. صُمم خصيصاً لتعزيز كفاءة أعمالك.
            </p>
            <div class="flex flex-wrap gap-4">
              <!-- تم التحديث: الرابط الآن يوجه إلى المسار الصحيح للوحة التحكم -->
              <a
                href="/brandzo-warehouse-system/dashboard/"
                class="px-10 py-5 bg-[#c0392b] text-white rounded-2xl font-bold text-xl shadow-2xl hover:bg-[#8b1a1a] transition-all transform hover:-translate-y-1 active:scale-95"
              >
                الدخول إلى لوحة التحكم
              </a>
              <!-- تم التحديث: الرابط الآن يوجه إلى المسار الصحيح للدليل -->
              <a
                href="/brandzo-warehouse-system/Brandzo_Operational_Guide.html"
                class="px-10 py-5 bg-transparent border-2 border-white text-white rounded-2xl font-bold text-xl hover:bg-white hover:text-[#1a1a2e] transition-all"
              >
                الدليل التشغيلي
              </a>
            </div>
          </div>
        </div>

        <!-- Decorative Elements -->
        <div class="hidden lg:block absolute left-0 bottom-20 w-1/3">
          <div class="grid grid-cols-2 gap-4 opacity-20">
            <div class="h-32 bg-white rounded-3xl"></div>
            <div class="h-32 bg-[#c0392b] rounded-3xl mt-12"></div>
            <div class="h-32 bg-[#c0392b] rounded-3xl"></div>
            <div class="h-32 bg-white rounded-3xl mt-12"></div>
          </div>
        </div>
      </section>

      <!-- Features Brief -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-shadow">
              <div
                class="w-14 h-14 bg-red-50 text-[#c0392b] rounded-2xl flex items-center justify-center mb-6"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M3 21h18"></path><path
                    d="M3 7v1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7H3l2-4h14l2 4"
                  ></path><path d="M5 21V10.85"></path><path d="M19 21V10.85"></path><path
                    d="M9 21v-4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4"></path></svg
                >
              </div>
              <h3 class="text-2xl font-bold mb-4">إدارة المستودعات</h3>
              <p class="text-gray-600 leading-relaxed">
                تحكم كامل في جميع فروعك ومستودعاتك من شاشة واحدة مع مزامنة لحظية.
              </p>
            </div>
            <div class="p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-shadow">
              <div
                class="w-14 h-14 bg-yellow-50 text-[#e8b830] rounded-2xl flex items-center justify-center mb-6"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="m7.5 4.27 9 5.15"></path><path
                    d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"
                  ></path><path d="m3.27 6.96 8.73 5.05 8.73-5.05"></path><path d="M12 22.08V12"
                  ></path></svg
                >
              </div>
              <h3 class="text-2xl font-bold mb-4">بطاقة الأصناف</h3>
              <p class="text-gray-600 leading-relaxed">
                تنظيم احترافي للأصناف، الفئات، ووحدات القياس مع تنبيهات نقص المخزون.
              </p>
            </div>
            <div class="p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-shadow">
              <div
                class="w-14 h-14 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center mb-6"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                  ></path><polyline points="14 2 14 8 20 8"></polyline><line
                    x1="12"
                    y1="18"
                    x2="12"
                    y2="12"></line><polyline points="9 15 12 12 15 15"></polyline></svg
                >
              </div>
              <h3 class="text-2xl font-bold mb-4">الاستلام الذكي</h3>
              <p class="text-gray-600 leading-relaxed">
                نظام استلام متطور يدعم الباركود والربط المباشر مع أوامر الشراء.
              </p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="py-12 bg-gray-50 border-t border-gray-200">
      <div class="container mx-auto px-6 text-center">
        <p class="text-gray-500 font-bold">
          Brandzo ERP اعداد محمد البرشي2026 &copy; جميع الحقوق محفوظة
        </p>
      </div>
    </footer>
  </body>
</html>
