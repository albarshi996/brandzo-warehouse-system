rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: any signed-in Firebase Auth user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: e-mail-verified user. (Sign-up flow can flip this on later if
    // we decide to enforce verification; today the helper exists so rules
    // can be tightened without touching every collection.)
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ------------------------------------------------------------------
    // Master data
    // ------------------------------------------------------------------
    match /Items_Master/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ------------------------------------------------------------------
    // Movement logs (append-only from the client; deletes are forbidden)
    // ------------------------------------------------------------------
    match /Inbound_Log/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /Outbound_Log/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /Adjustments_Log/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ------------------------------------------------------------------
    // Default deny: any collection not listed above is locked down.
    // ------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
